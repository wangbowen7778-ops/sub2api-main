<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sub2api.module.user.mapper.UserMapper">

    <resultMap id="BaseResultMap" type="com.sub2api.module.user.model.entity.User">
        <id column="id" property="id"/>
        <result column="email" property="email"/>
        <result column="password_hash" property="passwordHash"/>
        <result column="role" property="role"/>
        <result column="balance" property="balance"/>
        <result column="concurrency" property="concurrency"/>
        <result column="status" property="status"/>
        <result column="username" property="username"/>
        <result column="notes" property="notes"/>
        <result column="totp_secret_encrypted" property="totpSecretEncrypted"/>
        <result column="totp_enabled" property="totpEnabled"/>
        <result column="totp_enabled_at" property="totpEnabledAt"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
        <result column="deleted_at" property="deletedAt"/>
    </resultMap>

    <select id="selectByEmail" resultMap="BaseResultMap">
        SELECT * FROM users
        WHERE email = #{email}
        AND deleted_at IS NULL
    </select>

    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT * FROM users
        WHERE username = #{username}
        AND deleted_at IS NULL
    </select>

    <select id="selectActiveList" resultMap="BaseResultMap">
        SELECT * FROM users
        WHERE status = 'active'
        AND deleted_at IS NULL
        ORDER BY created_at DESC
    </select>

</mapper>
